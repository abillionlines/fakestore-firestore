// Firestore security rules example
// Replace or adapt to your project's auth and admin strategy.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Products: public read, writes restricted to admins (custom claim or UID list)
    match /products/{productId} {
      allow read: if true;
      // Example: require a custom claim `admin == true`
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Orders: allow creating when authenticated and userId matches, allow owners to read their orders
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // disallow updates/deletes in this example
    }
  }
}
